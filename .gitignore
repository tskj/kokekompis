# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — COMMITTED: the dotenvx-encrypted `.env` (shared secrets) + the non-secret per-environment
# config (`.env.development`). NEVER committed: the decryption key and personal overrides.
.env*
!.env
!.env.example
!.env.development
!.env.test
.env.keys
.env.local

# Railway project token — gitignored, used by `source .railway.env` for the railway CLI
.railway.env

# Local git worktrees created under .claude (e.g. by Claude Code) — never part of the repo
.claude/worktrees/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.lokal-lagring/
