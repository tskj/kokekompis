# Test environment config — COMMITTED (this isn't secret). Loaded by `pnpm db:setup:test` via
# dotenvx and by `tests/setup.ts` via dotenv, under any `.env.local` overrides (e.g. PGHOST).
#
# DATABASE_URL here is the BASE name, same scheme as `.env.development`: each git worktree derives
# kokekompis_test_<worktree> and auto-creates + migrates it (scripts/db-name.mjs).
PGHOST=/var/run/postgresql
DATABASE_URL=postgresql:///kokekompis_test
