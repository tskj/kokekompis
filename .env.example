# kokekompis environment contract.
#
# Philosophy: every environment's config is COMMITTED. Two committed files:
#   .env              dotenvx-ENCRYPTED shared secrets (below). Decrypted at runtime with the key.
#   .env.development  dev config, plaintext (DATABASE_URL base, NEXTAUTH_URL).
#
# NEVER committed (gitignored):
#   .env.keys         the dotenvx PRIVATE key that decrypts .env. Share out-of-band. On Railway set
#                     DOTENV_PRIVATE_KEY instead of this file.
#   .env.local        optional personal overrides, highest precedence. You rarely need it — each git
#                     worktree already gets its own dev DB automatically (see below).
#
# Per-worktree databases: DATABASE_URL in .env.development is a BASE name. The committed local config
# uses DATABASE_URL=postgresql:///... plus PGHOST=/var/run/postgresql so postgres.js connects over the
# local Unix socket and can use peer/trust auth without a password. Override PGHOST in .env.local if
# your local Postgres socket lives elsewhere. The main checkout uses the base DB name as-is; a linked
# git worktree derives kokekompis_dev_<worktree> and auto-creates + migrates it (scripts/db-name.mjs).
# Opt out of per-worktree DB names with NO_WORKTREE_DB=1.

# --- in the encrypted .env (shared across environments; edit with `dotenvx set KEY value`) ---
NEXTAUTH_SECRET=         # >= 32 chars; openssl rand -hex 32
GOOGLE_CLIENT_ID=        # OAuth — both ID + SECRET
GOOGLE_CLIENT_SECRET=

# --- prod-only, set as Railway service vars ---
DATABASE_URL=            # injected by Railway: ${{Postgres.DATABASE_URL}}
NEXTAUTH_URL=            # public origin, e.g. https://kokekompis.no
